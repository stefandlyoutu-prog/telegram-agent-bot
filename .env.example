TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
# Если Telegram не открывается — VPN или прокси (пример для локального SOCKS):
# TELEGRAM_PROXY=http://127.0.0.1:7890
# LLM_PROXY=http://127.0.0.1:7890
# Альтернатива SOCKS: socks5h://127.0.0.1:7891
LLM_BASE_URL=https://kupiapi.ru/v1
LLM_API_KEY=rk_live_...
# Если kupiapi.ru недоступен — тот же прокси, что для Telegram:
# LLM_PROXY=socks5://127.0.0.1:1080
# LLM_CONNECT_TIMEOUT_SEC=15
# xAI Imagine (https://console.x.ai) — редактирование фото. Не путать с Groq (gsk_...)
XAI_API_KEY=xai-...
GROK_API_KEY=
GEMINI_API_KEY=AIza...
# Запасной текстовый LLM, если KupiAPI недоступен (тот же ключ Google AI Studio)
LLM_GEMINI_FALLBACK=1
LLM_PRIMARY=auto
# auto = Kupi, при сбое → Gemini; gemini = только Google; kupi = без запасного
KUPI_CIRCUIT_SEC=300
GEMINI_CHAT_MODEL=gemini-2.5-flash
GEMINI_VISION_MODEL=gemini-2.5-flash
GROK_IMAGE_MODEL=grok-imagine-image-quality
IMAGE_PROVIDER_ORDER=auto
FREE_T2I_ENABLED=0
GROK_IMAGE_ENABLED=0
GEMINI_IMAGE_ENABLED=0
LAOZHANG_IMAGE_ENABLED=0
FREE_T2I_BASE_URL=https://t2i.mcpcore.xyz
FREE_T2I_FALLBACK_URL=https://subnp.com
FREE_T2I_MODEL=turbo
# LaoZhang Images API — https://docs.laozhang.ai/en/api-reference/images
LAOZHANG_API_KEY=
LAOZHANG_BASE_URL=https://api.laozhang.ai/v1
LAOZHANG_IMAGE_MODEL=gpt-image-1
LAOZHANG_TIMEOUT_SEC=300
# Unsplash — https://unsplash.com/oauth/applications (Public access, Access Key)
UNSPLASH_ACCESS_KEY=
UNSPLASH_ENABLED=1
UNSPLASH_TIMEOUT_SEC=30
DEFAULT_MODEL=gpt-4o-mini
MAX_HISTORY_TURNS=20
# Опционально: Meshy image-to-3D для STL с фото (точнее примитивов)
# MESHY_API_KEY=
# MESHY_TIMEOUT_SEC=180
# Текст при «не умею» — обучение через Агента
# AGENT_CONTACT_HINT=Напишите нашему Агенту в Cursor...
# Локальный экспорт STL из OpenSCAD (brew install openscad)
# OPENSCAD_PATH=/usr/local/bin/openscad
# Meshy 3D — https://www.meshy.ai
# MESHY_API_KEY=msy_...
# Маршрутизация задач + самопроверка (выключить позже: SELF_CHECK_ENABLED=0)
# TASK_ROUTER_ANNOUNCE=1
# SELF_CHECK_ENABLED=1
# SELF_CHECK_MODEL=gpt-5.4-mini
# MODEL_ENGINEERING=gpt-5.4
# Google Cloud (ADC — не API-ключ). Голосовые → Speech-to-Text
# GCP_PROJECT_ID=my-project-123
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
# GCP_SPEECH_ENABLED=1
# GCP_SPEECH_LANGUAGE=ru-RU
# GCP_STT_KUPI_FALLBACK=1
# GCP_STT_KUPI_MODEL=whisper-1
# GCP_STT_GEMINI_FALLBACK=1
# GCP_TTS_ENABLED=1
# GCP_TTS_VOICE=ru-RU-Chirp3-HD-Charon
# GCP_VISION_ENABLED=1
# GCP_TRANSLATE_ENABLED=1
# Автопилот: не спрашивать принтер/материал (дефолт P2S+PLA)
# DEFAULT_AUTO_PROCEED=1
# DEFAULT_PRINTER=Bambu Lab P2S
# DEFAULT_MATERIAL=PLA
# DEFAULT_NOZZLE_MM=0.4
# TASK_ROUTER_ANNOUNCE=1
# DEFAULT_NOZZLE_MM=0.4
# TASK_ROUTER_ANNOUNCE=1
# MESHY_RIG_TIMEOUT_SEC=600

# --- Центр доходов (дашборд + /money) ---
